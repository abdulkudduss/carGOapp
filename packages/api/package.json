{
  "name": "@cargo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "gen:types": "openapi-typescript ${OPENAPI_URL:-http://localhost:8080/api-docs} -o src/generated/schema.ts",
    "smoke": "node scripts/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0"
  }
}
