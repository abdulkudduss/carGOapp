# Dependencies
node_modules/

# Build output
dist/
build/
web-build/
dev-dist/
storybook-static/
*.tsbuildinfo

# Exception: @cargo/tokens ships generated CSS (variables.css + theme.css) as a
# committed artifact so every app build / dev server is deterministic without an
# ordering dependency on a token build step. Regenerate with `pnpm --filter
# @cargo/tokens gen:css`.
!packages/tokens/dist/
!packages/tokens/dist/**

# Expo / React Native
.expo/
.expo-shared/
*.orig.*

# Vite
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Claude Code local settings
.claude/
